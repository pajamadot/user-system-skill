{
  "name": "user-system-skill",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production-ready multi-tenant user system with Clerk, MCP auth, CLI OAuth, and automated E2E testing",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "migrate": "tsx src/db/migrate.ts",
    "setup": "docker compose up -d db && sleep 2 && npm run migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "self-eval": "tsx tests/meta/self-eval.ts",
    "assumption-test": "tsx tests/meta/assumption-tests.ts",
    "eval": "npm run self-eval && npm run assumption-test",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:e2e:headed": "playwright test --config tests/playwright.config.ts --headed",
    "worker:dev": "cd email-receiver-worker && npx wrangler dev",
    "worker:deploy": "cd email-receiver-worker && npx wrangler deploy",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts tests/integration/",
    "test:integration:watch": "vitest --config tests/integration/vitest.config.ts tests/integration/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/backend": "^2.0.0",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "jsonwebtoken": "^9.0.0",
    "postgres": "^3.4.0",
    "svix": "^1.42.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
