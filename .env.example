# ============================================================
# User System — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# === Auth Provider (Clerk) ===
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_WEBHOOK_SECRET=whsec_xxxx

# Frontend routes (customize to match your app)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# === Database ===
DATABASE_URL=postgresql://user:pass@localhost:5432/myapp

# === JWT (for service-to-service tokens, optional) ===
# Generate with: openssl genrsa 2048 > private.pem && openssl rsa -in private.pem -pubout > public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
JWT_EXPIRY_SECONDS=900

# === Email Testing — Pick ONE approach ===

# --- Option A: Cloudflare Email Routing + Worker ---
# EMAIL_WORKER_URL=https://email-receiver.your-subdomain.workers.dev
# CLOUDFLARE_EMAIL_ROUTING_DOMAIN=test.yourdomain.com
# EMAIL_WORKER_TOKEN=generate-a-random-secret-here

# --- Option B: Mailosaur ---
# MAILOSAUR_API_KEY=your-api-key
# MAILOSAUR_SERVER_ID=your-server-id
# MAILOSAUR_DOMAIN=xxx.mailosaur.net

# --- Option C: MailSlurp ---
# MAILSLURP_API_KEY=your-api-key

# === E2E Test User (pre-created, for sign-in tests) ===
E2E_TEST_USER_EMAIL=test-permanent@test.yourdomain.com
E2E_TEST_USER_PASSWORD=TestPass123!

# === API ===
API_BASE_URL=http://localhost:8080
